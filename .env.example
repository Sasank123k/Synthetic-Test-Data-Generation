# ============================================
# Synthetic Data Engine — Environment Template
# Copy this file to backend/.env and fill in
# ============================================

# --- LLM Provider (choose one: "gemini" or "openai") ---
LLM_PROVIDER=gemini

# --- Gemini Configuration (recommended) ---
GEMINI_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash
# Get your key at: https://aistudio.google.com/apikey

# --- OpenAI Configuration (alternative) ---
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# --- Actor-Critic Pipeline ---
MAX_RETRIES=2

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
FRONTEND_URL=http://localhost:5173

# --- Data Export ---
DATA_VOLUME_PATH=./data-volumes
